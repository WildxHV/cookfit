# Copy to .env and adjust as needed.

# Dev default: SQLite file in backend/. No install required.
DATABASE_URL=sqlite:///./cookfit.db

# Production example (PostgreSQL):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/cookfit

# CORS: comma-separated origins allowed to call the API (the frontend dev server).
CORS_ORIGINS=http://localhost:5173

# --- AI providers ----------------------------------------------------------
# The AI layer tries a POOL of backends in round-robin with fallback, so one
# provider's rate limit never fails a request. Configure any subset; at least
# one key is needed for AI features.

# Google Gemini (free tier) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Extra Gemini models to fall back to (each has its own free quota).
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-flash-latest,gemini-2.0-flash

# Optional extra providers (all OpenAI-compatible). Leave blank to skip.
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Grok / x.ai — https://console.x.ai
XAI_API_KEY=
XAI_MODEL=grok-2-1212
# Groq (fast, generous free tier) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
